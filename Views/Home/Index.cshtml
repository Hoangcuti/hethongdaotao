@{
    ViewData["Title"] = "Corporate LMS - Nền Tảng Đào Tạo Nội Bộ Toàn Diện";
    Layout = null; // Bỏ qua layout admin mặc định
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Corporate LMS - Tối Ưu Hóa Năng Lực Đội Ngũ</title>
    <meta name="description" content="Hệ thống quản lý đào tạo nội bộ doanh nghiệp toàn diện. Số hóa quy trình học tập, tối ưu hóa tri thức và bứt phá hiệu năng nhân sự." />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Phosphor Icons -->
    <script src="https://unpkg.com/@@phosphor-icons/web"></script>

    <style>
        :root {
            --primary: #4F46E5;
            --primary-hover: #4338CA;
            --primary-glow: rgba(79, 70, 229, 0.4);
            --secondary: #06B6D4;
            --secondary-glow: rgba(6, 182, 212, 0.3);
            --accent-pain: #F43F5E;
            --accent-pain-glow: rgba(244, 63, 94, 0.15);
            --accent-sol: #10B981;
            --accent-sol-glow: rgba(16, 185, 129, 0.15);
            --dark: #090a0f;
            --dark-light: #131520;
            --dark-card: #1c1f30;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --glass-bg: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.08);
            --font-display: 'Outfit', sans-serif;
            --font-text: 'Inter', sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            scroll-behavior: smooth;
        }

        body {
            font-family: var(--font-text);
            background-color: var(--dark);
            color: var(--text-main);
            overflow-x: hidden;
            line-height: 1.6;
        }

        h1, h2, h3, h4, .font-display {
            font-family: var(--font-display);
            letter-spacing: -0.02em;
        }

        /* --- Background Mesh Animation --- */
        .bg-mesh {
            position: absolute;
            top: 0; left: 0; width: 100vw; height: 120vh;
            overflow: hidden;
            z-index: -1;
            background: linear-gradient(180deg, #090a0f 0%, #131520 100%);
            pointer-events: none;
        }
        
        .blob {
            position: absolute;
            filter: blur(120px);
            border-radius: 50%;
            opacity: 0.45;
            animation: float 25s infinite ease-in-out alternate;
        }

        .blob-1 { top: -10%; left: -10%; width: 50vw; height: 50vw; background: var(--primary-glow); animation-delay: 0s; }
        .blob-2 { bottom: 10%; right: -10%; width: 55vw; height: 55vw; background: var(--secondary-glow); animation-delay: -5s; }
        .blob-3 { top: 35%; left: 35%; width: 35vw; height: 35vw; background: rgba(99, 102, 241, 0.2); animation-delay: -10s; }

        @@keyframes float {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(8%, 12%) scale(1.15); }
        }

        /* --- Navigation --- */
        header {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            width: 90%;
            max-width: 1200px;
            padding: 16px 32px;
            background: rgba(13, 14, 21, 0.7);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 100px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            transition: all 0.3s ease;
        }

        header.scrolled {
            top: 0;
            width: 100%;
            border-radius: 0;
            border-left: none;
            border-right: none;
            border-top: none;
            background: rgba(9, 10, 15, 0.9);
            padding: 14px 5%;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 22px;
            font-weight: 800;
            color: #fff;
            text-decoration: none;
        }

        .brand i {
            font-size: 28px;
            background: linear-gradient(135deg, var(--secondary), var(--primary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-menu {
            display: flex;
            gap: 30px;
            align-items: center;
            list-style: none;
        }

        .nav-link {
            color: var(--text-muted);
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: color 0.3s ease;
        }

        .nav-link:hover {
            color: #fff;
        }

        .btn-nav-login {
            padding: 10px 24px;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid var(--glass-border);
            color: #fff;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn-nav-login:hover {
            background: #fff;
            color: var(--dark);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(255, 255, 255, 0.2);
        }

        /* --- Global Sections --- */
        section {
            padding: 120px 5%;
            position: relative;
            max-width: 1300px;
            margin: 0 auto;
        }

        .section-tag {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--glass-border);
            padding: 6px 16px;
            border-radius: 100px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 20px;
        }

        .section-tag.pain { color: var(--accent-pain); }
        .section-tag.sol { color: var(--accent-sol); }
        .section-tag.primary { color: var(--secondary); }

        .section-title {
            font-size: clamp(32px, 4vw, 48px);
            font-weight: 800;
            line-height: 1.15;
            margin-bottom: 20px;
            max-width: 800px;
        }

        .section-desc {
            font-size: 18px;
            color: var(--text-muted);
            max-width: 650px;
            margin-bottom: 50px;
        }

        /* --- Hero Section --- */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding-top: 150px;
            padding-bottom: 80px;
        }

        .hero-container {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            gap: 50px;
            align-items: center;
            width: 100%;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(79, 70, 229, 0.1);
            border: 1px solid rgba(79, 70, 229, 0.2);
            color: #818cf8;
            padding: 8px 16px;
            border-radius: 100px;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 24px;
        }

        .hero-badge span {
            width: 8px;
            height: 8px;
            background: var(--secondary);
            border-radius: 50%;
            box-shadow: 0 0 10px var(--secondary);
        }

        .hero h1 {
            font-size: clamp(40px, 5.5vw, 68px);
            font-weight: 900;
            line-height: 1.1;
            margin-bottom: 24px;
            color: #fff;
        }

        .hero-gradient {
            background: linear-gradient(135deg, #fff 20%, var(--secondary) 60%, var(--primary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero p {
            font-size: clamp(16px, 1.8vw, 19px);
            color: var(--text-muted);
            margin-bottom: 40px;
            max-width: 650px;
        }

        .hero-actions {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
        }

        .btn-primary {
            padding: 16px 36px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: #fff;
            border-radius: 50px;
            font-size: 16px;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            border: 1px solid rgba(255, 255, 255, 0.15);
            display: inline-flex;
            align-items: center;
            gap: 10px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 10px 25px rgba(79, 70, 229, 0.4);
        }

        .btn-primary::before {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
            transition: left 0.6s ease;
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(79, 70, 229, 0.55);
        }

        .btn-primary:hover::before {
            left: 100%;
        }

        .btn-secondary {
            padding: 16px 36px;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--glass-border);
            color: #fff;
            border-radius: 50px;
            font-size: 16px;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.09);
            border-color: rgba(255, 255, 255, 0.2);
            transform: translateY(-2px);
        }

        /* --- Interactive Mockup Dashboard (Hero Right) --- */
        .mockup-container {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .mockup-dashboard {
            width: 100%;
            max-width: 440px;
            background: rgba(22, 24, 38, 0.7);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 24px;
            padding: 24px;
            box-shadow: 0 30px 60px rgba(0,0,0,0.6);
            backdrop-filter: blur(10px);
            position: relative;
            animation: floatCard 6s infinite ease-in-out;
        }

        @@keyframes floatCard {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-12px); }
        }

        .mockup-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            border-bottom: 1px solid rgba(255,255,255,0.06);
            padding-bottom: 12px;
        }

        .mockup-dots {
            display: flex;
            gap: 6px;
        }

        .mockup-dot {
            width: 8px; height: 8px;
            border-radius: 50%;
        }
        .mockup-dot.r { background: #ef4444; }
        .mockup-dot.y { background: #f59e0b; }
        .mockup-dot.g { background: #10b981; }

        .mockup-title {
            font-size: 11px;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        .mockup-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 14px;
            margin-bottom: 20px;
        }

        .mockup-card {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.05);
            padding: 14px;
            border-radius: 16px;
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .mockup-card-label {
            font-size: 11px;
            color: var(--text-muted);
        }

        .mockup-card-val {
            font-size: 18px;
            font-weight: 700;
            color: #fff;
        }

        .mockup-progress-sec {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.05);
            padding: 16px;
            border-radius: 16px;
            margin-bottom: 14px;
        }

        .mockup-progress-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .mockup-progress-title {
            font-size: 12px;
            font-weight: 600;
        }

        .mockup-progress-pct {
            font-size: 12px;
            font-weight: 700;
            color: var(--secondary);
        }

        .mockup-progress-bar {
            height: 6px;
            background: rgba(255,255,255,0.08);
            border-radius: 10px;
            overflow: hidden;
        }

        .mockup-progress-fill {
            width: 78%;
            height: 100%;
            background: linear-gradient(90deg, var(--primary), var(--secondary));
            border-radius: 10px;
        }

        .mockup-badge {
            position: absolute;
            background: rgba(16, 185, 129, 0.15);
            border: 1px solid rgba(16, 185, 129, 0.3);
            color: #34d399;
            padding: 8px 16px;
            border-radius: 14px;
            font-size: 12px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 6px;
            top: -20px;
            right: -20px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.3);
            animation: floatBadge 4s infinite ease-in-out alternate;
        }

        .mockup-badge-2 {
            position: absolute;
            background: rgba(245, 158, 11, 0.15);
            border: 1px solid rgba(245, 158, 11, 0.3);
            color: #fbbf24;
            padding: 8px 16px;
            border-radius: 14px;
            font-size: 12px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 6px;
            bottom: -15px;
            left: -20px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.3);
            animation: floatBadge2 5s infinite ease-in-out alternate;
        }

        @@keyframes floatBadge {
            0% { transform: translateY(0); }
            100% { transform: translateY(-8px); }
        }

        @@keyframes floatBadge2 {
            0% { transform: translateY(0); }
            100% { transform: translateY(8px); }
        }

        /* --- Zebra Striping Sections --- */
        
        /* Dải 1: Hero (Tối - Đã định nghĩa nền body mặc định) */

        /* Dải 2: Pain Points (Nền tối xám/xanh nhẹ tạo tương phản nhẹ) */
        .pain-points-section {
            background-color: var(--dark-light);
            border-top: 1px solid rgba(255,255,255,0.03);
            border-bottom: 1px solid rgba(255,255,255,0.03);
        }

        .pain-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 24px;
        }

        .pain-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 20px;
            padding: 36px 28px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }

        .pain-card::after {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at top right, var(--accent-pain-glow), transparent 45%);
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .pain-card:hover {
            transform: translateY(-6px);
            border-color: rgba(244, 63, 94, 0.3);
            background: rgba(255, 255, 255, 0.04);
            box-shadow: 0 15px 30px rgba(0,0,0,0.3);
        }

        .pain-card:hover::after {
            opacity: 1;
        }

        .pain-icon-wrapper {
            width: 54px;
            height: 54px;
            background: rgba(244, 63, 94, 0.08);
            border: 1px solid rgba(244, 63, 94, 0.15);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 24px;
            color: var(--accent-pain);
            font-size: 24px;
            transition: all 0.3s ease;
        }

        .pain-card:hover .pain-icon-wrapper {
            background: var(--accent-pain);
            color: #fff;
            transform: scale(1.05);
            box-shadow: 0 0 15px rgba(244, 63, 94, 0.4);
        }

        .pain-card h3 {
            font-size: 20px;
            font-weight: 700;
            color: #fff;
            margin-bottom: 12px;
            position: relative;
            z-index: 1;
        }

        .pain-card p {
            font-size: 14px;
            color: var(--text-muted);
            line-height: 1.6;
            position: relative;
            z-index: 1;
        }

        /* Dải 3: Solutions (Nền cực tối - làm nổi bật giải pháp bằng các ánh sáng xanh) */
        .solutions-section {
            background-color: var(--dark);
        }

        .sol-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
        }

        .sol-card {
            background: linear-gradient(145deg, rgba(255, 255, 255, 0.01) 0%, rgba(255, 255, 255, 0.03) 100%);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 24px;
            padding: 40px;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .sol-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 4px;
            background: linear-gradient(90deg, var(--secondary), var(--accent-sol));
            opacity: 0;
            transition: opacity 0.4s ease;
        }

        .sol-card:hover {
            transform: translateY(-8px);
            border-color: rgba(16, 185, 129, 0.25);
            background: rgba(22, 25, 41, 0.6);
            box-shadow: 0 20px 40px rgba(0,0,0,0.4), 0 0 30px rgba(16, 185, 129, 0.05);
        }

        .sol-card:hover::before {
            opacity: 1;
        }

        .sol-icon-wrapper {
            width: 60px;
            height: 60px;
            background: rgba(16, 185, 129, 0.08);
            border: 1px solid rgba(16, 185, 129, 0.15);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 28px;
            color: var(--accent-sol);
            font-size: 28px;
            transition: all 0.3s ease;
        }

        .sol-card:hover .sol-icon-wrapper {
            background: var(--accent-sol);
            color: #fff;
            transform: scale(1.05);
            box-shadow: 0 0 18px rgba(16, 185, 129, 0.4);
        }

        .sol-card h3 {
            font-size: 22px;
            font-weight: 700;
            color: #fff;
            margin-bottom: 14px;
        }

        .sol-card p {
            font-size: 15px;
            color: var(--text-muted);
            line-height: 1.6;
            flex-grow: 1;
        }

        /* --- Stats/Benefits Highlight --- */
        .benefits-section {
            background-color: var(--dark-light);
            padding-bottom: 100px;
        }

        .benefits-container {
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            gap: 60px;
            align-items: center;
        }

        .benefits-stats {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }

        .b-stat-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid var(--glass-border);
            padding: 30px 24px;
            border-radius: 20px;
            text-align: center;
        }

        .b-stat-num {
            font-size: 44px;
            font-weight: 800;
            color: #fff;
            margin-bottom: 6px;
            background: linear-gradient(135deg, #fff, var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .b-stat-lbl {
            font-size: 13px;
            color: var(--text-muted);
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .benefits-list {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .benefit-item {
            display: flex;
            gap: 16px;
            align-items: flex-start;
        }

        .benefit-check {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            background: rgba(16, 185, 129, 0.1);
            color: var(--accent-sol);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            flex-shrink: 0;
            margin-top: 3px;
        }

        .benefit-content h4 {
            font-size: 17px;
            font-weight: 700;
            color: #fff;
            margin-bottom: 4px;
        }

        .benefit-content p {
            font-size: 14px;
            color: var(--text-muted);
        }

        /* --- Call to Action Section --- */
        .cta-section {
            background-color: var(--dark);
            padding: 100px 5%;
        }

        .cta-box {
            background: linear-gradient(135deg, rgba(79, 70, 229, 0.2) 0%, rgba(6, 182, 212, 0.1) 100%);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 32px;
            padding: 80px 40px;
            text-align: center;
            max-width: 1000px;
            margin: 0 auto;
            position: relative;
            overflow: hidden;
            box-shadow: 0 20px 50px rgba(0,0,0,0.4);
        }

        .cta-box::before {
            content: '';
            position: absolute;
            width: 300px; height: 300px;
            background: radial-gradient(circle, rgba(6, 182, 212, 0.15) 0%, transparent 70%);
            top: -100px; left: -100px;
        }

        .cta-box::after {
            content: '';
            position: absolute;
            width: 350px; height: 350px;
            background: radial-gradient(circle, rgba(79, 70, 229, 0.15) 0%, transparent 70%);
            bottom: -150px; right: -100px;
        }

        .cta-box h2 {
            font-size: clamp(28px, 3.5vw, 44px);
            font-weight: 800;
            color: #fff;
            margin-bottom: 16px;
            position: relative;
            z-index: 1;
        }

        .cta-box p {
            font-size: 16px;
            color: var(--text-muted);
            max-width: 600px;
            margin: 0 auto 36px;
            position: relative;
            z-index: 1;
        }

        .cta-actions {
            position: relative;
            z-index: 1;
        }

        /* --- Footer --- */
        footer {
            background: #06070a;
            padding: 80px 5% 40px;
            border-top: 1px solid rgba(255,255,255,0.03);
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 1.5fr 1fr 1fr;
            gap: 40px;
            max-width: 1200px;
            margin: 0 auto 60px;
        }

        .footer-brand p {
