@using System.Security.Claims
@{
    var role = User.FindFirst(ClaimTypes.Role)?.Value ?? Context.Session.GetString("Role") ?? "Employee";
    var fullName = User.FindFirst("FullName")?.Value ?? Context.Session.GetString("FullName") ?? "Nguoi dung";
    var deptName = User.FindFirst("DepartmentName")?.Value ?? Context.Session.GetString("DepartmentName") ?? "No department";
    var deptEmail = User.FindFirst("DepartmentEmail")?.Value ?? "N/A";
    var initialSource = string.IsNullOrWhiteSpace(fullName) ? "ND" : new string(fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => char.ToUpperInvariant(x[0])).ToArray());
    var initials = string.IsNullOrWhiteSpace(initialSource) ? "ND" : initialSource;
    var roleLabel = role switch
    {
        "IT" => "System",
        "Manager" => "Department Lead",
        "HR" => "HR",
        "Student" => "Student",
        _ => role
    };
}
<!DOCTYPE html>
<html lang="vi" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Xôi Ngô Edu</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/design-tokens.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://unpkg.com/@@phosphor-icons/web"></script>
    <style>
        .swal2-popup { border-radius: 18px !important; font-family: var(--font-text) !important; }
        .swal2-title { font-family: var(--font-display) !important; font-weight: 600 !important; }
        .swal2-styled.swal2-confirm { background-color: var(--color-primary) !important; border-radius: 9999px !important; padding: 10px 22px !important; }
        .swal2-styled.swal2-cancel { border-radius: 9999px !important; }
    </style>
    @RenderSection("Header", required: false)
</head>
<body data-role="@role">
    <div class="sidebar-backdrop" id="sidebarBackdrop" onclick="setSidebarOpen(false)"></div>

    <div class="dashboard-shell app-shell" data-role="@role">
        <aside class="sidebar" id="appSidebar">
            <div class="sidebar-brand">
                <a href="/" class="sidebar-logo">
                    <img src="/favicon.ico" alt="Logo" class="sidebar-logo-icon" style="width: 36px; height: 36px; border-radius: 8px; object-fit: contain; background: white; padding: 2px;" />
                    <span class="sidebar-logo-text">
                        <span class="brand-name">Xôi Ngô Edu</span>
                        <span class="brand-sub">@roleLabel workspace</span>
                    </span>
                </a>
            </div>

            <nav class="sidebar-nav" aria-label="Sidebar navigation">
                @if (role != "Student")
                {
                    <div class="nav-section-label">Tổng quan</div>
                    <ul>
                        <li class="nav-item">
                            <a class="nav-link active" onclick="location.href='@Url.Action("Index", role == "IT" ? "IT" : "HR")'">
                                <span class="nav-icon"><i class="ph ph-house"></i></span>
                                <span class="nav-text">Dashboard</span>
                            </a>
                        </li>
                    </ul>
                }

                @if (role == "Student")
                {
                    <div class="nav-section-label">Tổng quan</div>
                    <ul>
                        <li class="nav-item">
                            <a class="nav-link active" data-page="dashboard" href="#">
                                <span class="nav-icon"><i class="ph ph-house"></i></span>
                                <span class="nav-text">Dashboard</span>
                            </a>
                        </li>
                    </ul>

                    <div class="nav-section-label">Học tập</div>
                    <ul>
                        <li class="nav-item">
                            <a class="nav-link" data-page="courses" href="#">
                                <span class="nav-icon"><i class="ph ph-graduation-cap"></i></span>
                                <span class="nav-text">Chương trình đào tạo</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-page="my-courses" href="#">
                                <span class="nav-icon"><i class="ph ph-play-circle"></i></span>
                                <span class="nav-text">Khóa đang học</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-page="learning-paths" href="#">
                                <span class="nav-icon"><i class="ph ph-map-trifold"></i></span>
                                <span class="nav-text">Lộ trình học</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-page="study-schedule" href="#">
                                <span class="nav-icon"><i class="ph ph-calendar"></i></span>
                                <span class="nav-text">Lịch học tập</span>
                            </a>
                        </li>
                    </ul>

                    <div class="nav-section-label">Kết quả & đánh giá</div>
                    <ul>
                        <li class="nav-item">
                            <a class="nav-link" data-page="exam-history" href="#">
                                <span class="nav-icon"><i class="ph ph-file-text"></i></span>
                                <span class="nav-text">Lịch sử thi</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-page="certificates" href="#">
                                <span class="nav-icon"><i class="ph ph-certificate"></i></span>
                                <span class="nav-text">Chứng chỉ</span>
                            </a>
                        </li>
                    </ul>

                    <div class="nav-section-label">Tài khoản</div>
                    <ul>
                        <li class="nav-item">
                            <a class="nav-link" data-page="notifications" href="#">
                                <span class="nav-icon" style="position:relative;">
                                    <i class="ph ph-bell"></i>
                                    <span class="nav-badge" id="notifBadge" style="position:absolute; top:-2px; right:-2px; background:#ef4444; color:#fff; font-size:9px; font-weight:700; width:16px; height:16px; display:flex; align-items:center; justify-content:center; border-radius:50%; border:2px solid #fff; display:none;">0</span>
                                </span>
                                <span class="nav-text">Thông báo</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-page="profile" href="#">
                                <span class="nav-icon"><i class="ph ph-user"></i></span>
                                <span class="nav-text">Hồ sơ cá nhân</span>
                            </a>
                        </li>
                    </ul>
                }

                @if (role == "Manager" || role == "Trainer" || role == "Lecturer")
                {
                    <div class="nav-section-label">Phòng ban</div>
                    <ul>
                        @if (role == "Manager")
                        {
                            <li class="nav-item"><a class="nav-link" onclick="navigate('members')"><span class="nav-icon"><i class="ph ph-users"></i></span><span class="nav-text">Nhân viên</span></a></li>
                        }
                        <li class="nav-item"><a class="nav-link" onclick="navigate('courses')"><span class="nav-icon"><i class="ph ph-books"></i></span><span class="nav-text">Khóa học</span></a></li>
                        <li class="nav-item"><a class="nav-link" onclick="navigate('exams')"><span class="nav-icon"><i class="ph ph-exam"></i></span><span class="nav-text">Bài thi</span></a></li>
                        @if (role == "Manager")
                        {
                            <li class="nav-item"><a class="nav-link" onclick="navigate('assignments')"><span class="nav-icon"><i class="ph ph-arrow-up-right"></i></span><span class="nav-text">Phân công</span></a></li>
                            <li class="nav-item"><a class="nav-link" onclick="navigate('staff-progress')"><span class="nav-icon"><i class="ph ph-chart-pie"></i></span><span class="nav-text">Tiến độ</span></a></li>
                            <li class="nav-item"><a class="nav-link" onclick="navigate('hr-notifications')"><span class="nav-icon"><i class="ph ph-bell"></i></span><span class="nav-text">Thông báo</span></a></li>
                            @if (deptName == "Trung tâm Đào tạo Nội bộ")
                            {
                                <li class="nav-item"><a class="nav-link" onclick="navigate('approvals')"><span class="nav-icon"><i class="ph ph-check-circle"></i></span><span class="nav-text">Phê duyệt</span></a></li>
                            }
                        }
                        <li class="nav-item"><a class="nav-link" onclick="navigate('documents')"><span class="nav-icon"><i class="ph ph-folder"></i></span><span class="nav-text">Tài liệu</span></a></li>
                    </ul>
                }

                @if (role == "IT")
                {
                    <div class="nav-section-label">Quản trị</div>
                    <ul>
                        <li class="nav-item"><a class="nav-link" data-permission="users.manage" data-nav-page="users" onclick="navigate('users')"><span class="nav-icon"><i class="ph ph-user"></i></span><span class="nav-text">Người dùng</span></a></li>
                        <li class="nav-item"><a class="nav-link" data-permission="departments.manage" data-nav-page="departments" onclick="navigate('departments')"><span class="nav-icon"><i class="ph ph-buildings"></i></span><span class="nav-text">Phòng ban</span></a></li>
                        <li class="nav-item"><a class="nav-link" data-permission="courses.manage" data-nav-page="courses" onclick="navigate('courses')"><span class="nav-icon"><i class="ph ph-book-open"></i></span><span class="nav-text">Khóa học</span></a></li>
                        <li class="nav-item"><a class="nav-link" data-permission="courses.manage" data-nav-page="exams" onclick="navigate('exams')"><span class="nav-icon"><i class="ph ph-exam"></i></span><span class="nav-text">Bài thi</span></a></li>
                        <li class="nav-item"><a class="nav-link" data-permission="categories.manage" data-nav-page="categories" onclick="navigate('categories')"><span class="nav-icon"><i class="ph ph-squares-four"></i></span><span class="nav-text">Danh mục</span></a></li>
                        <li class="nav-item"><a class="nav-link" data-permission="faqs.manage" data-nav-page="faqs" onclick="navigate('faqs')"><span class="nav-icon"><i class="ph ph-question"></i></span><span class="nav-text">FAQ</span></a></li>
                        <li class="nav-item"><a class="nav-link" data-permission="content.documents.manage" data-nav-page="documents" onclick="navigate('documents')"><span class="nav-icon"><i class="ph ph-folder"></i></span><span class="nav-text">Tài liệu</span></a></li>
                        <li class="nav-item"><a class="nav-link" data-nav-page="approvals" onclick="navigate('approvals')"><span class="nav-icon"><i class="ph ph-check-circle"></i></span><span class="nav-text">Phê duyệt</span></a></li>
                    </ul>

                    <div class="nav-section-label">Vận hành</div>
                    <ul>
                        <li class="nav-item"><a class="nav-link" data-permission="analytics.view" data-nav-page="analytics" onclick="navigate('analytics')"><span class="nav-icon"><i class="ph ph-chart-bar"></i></span><span class="nav-text">Phân tích</span></a></li>
                        <li class="nav-item"><a class="nav-link" data-permission="auditlogs.view" data-nav-page="auditlogs" onclick="navigate('auditlogs')"><span class="nav-icon"><i class="ph ph-list-dashes"></i></span><span class="nav-text">Nhật ký hệ thống</span></a></li>
                        <li class="nav-item"><a class="nav-link" data-permission="backup.manage" data-nav-page="backup" onclick="navigate('backup')"><span class="nav-icon"><i class="ph ph-database"></i></span><span class="nav-text">Sao lưu</span></a></li>
                        <li class="nav-item"><a class="nav-link" data-permission="newsletter.manage" data-nav-page="newsletter" onclick="navigate('newsletter')"><span class="nav-icon"><i class="ph ph-envelope-simple"></i></span><span class="nav-text">Thông báo hệ thống</span></a></li>
                        <li class="nav-item"><a class="nav-link" data-permission="settings.manage" data-nav-page="settings" onclick="navigate('settings')"><span class="nav-icon"><i class="ph ph-gear"></i></span><span class="nav-text">Cài đặt</span></a></li>
                    </ul>
                }

                <div class="nav-section-label">Tài khoản</div>
                <ul>
                    <li class="nav-item">
                        <a class="nav-link" href="/Auth/Logout">
                            <span class="nav-icon"><i class="ph ph-sign-out"></i></span>
                            <span class="nav-text">Đăng xuất</span>
                        </a>
                    </li>
                </ul>

                <div class="nav-section-label">Tùy chọn</div>
                <ul>
                    <li class="nav-item">
                        <button id="themeToggleBtn" type="button" class="nav-link" onclick="toggleTheme()">
                            <span class="nav-icon"><i class="ph ph-moon"></i></span>
                            <span class="nav-text">Giao diện</span>
                        </button>
                    </li>
                </ul>
            </nav>


        </aside>

        <main class="main-content">
            <header class="app-topbar">
                <div class="topbar-title-group">
                    <div class="topbar-overline">Internal learning platform</div>
                    <div class="page-title" id="pageTitle">@ViewData["Title"]</div>
                    <div class="page-subtitle" id="pageSubtitle">@deptName</div>
                </div>
                <div class="topbar-actions" style="display:flex; align-items:center; gap:16px;">
                    @if (role == "IT")
                    {
                        <div class="header-search-wrap hidden-mobile">
                            <i class="ph ph-magnifying-glass" style="color:#94a3b8; font-size:16px;"></i>
                            <input type="text" placeholder="Tìm người dùng, khóa học, bài thi..." />
                        </div>
                        <div class="hidden-mobile" style="font-size:12px; color:#64748b; font-weight:500; display:flex; align-items:center; gap:4px;">
                            <i class="ph ph-arrows-clockwise"></i> Last Sync: <span id="headerSyncTime" style="color:#0f172a; font-weight:600;">--/--/---- --:--</span>
                        </div>
                    }
                    @if (role == "Student")
                    {
                        <div class="hidden-mobile" style="font-size:12px; color:#64748b; font-weight:500; display:flex; align-items:center; gap:4px;">
                            <i class="ph ph-calendar"></i> Hôm nay: <span id="todayLabel" style="color:#0f172a; font-weight:600;"></span>
                        </div>
                    }
                    <button type="button" class="btn btn-secondary btn-icon topbar-menu-trigger mobile-only" aria-label="Open navigation" onclick="setSidebarOpen(true)"><i class="ph ph-list"></i></button>
                    <button type="button" class="btn btn-secondary btn-icon" aria-label="Notifications" style="position:relative;">
                        <i class="ph ph-bell"></i>
                        @if (role == "IT" || role == "Student")
                        {
                            <span id="headerNotifBadge" style="position:absolute; top:-2px; right:-2px; background:#ef4444; color:#fff; font-size:9px; font-weight:700; width:16px; height:16px; display:flex; align-items:center; justify-content:center; border-radius:50%; display:none; border:2px solid #fff;">0</span>
                        }
                    </button>
                    <div class="topbar-user">
                        <span class="topbar-avatar">@initials</span>
                        <div class="topbar-user-copy">
                            <span class="topbar-user-name">@fullName</span>
                            <span class="topbar-user-role">@roleLabel</span>
                        </div>
                    </div>
                </div>
            </header>

            @RenderBody()
        </main>
    </div>

    @RenderSection("Modals", required: false)

    <script src="~/js/app.js"></script>
    <script>
        function startApp() {
            initializeTheme();
            initializeShell();
        }
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', startApp);
        } else {
            startApp();
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
