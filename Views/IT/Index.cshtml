                </div>
            </div>
        </div>
    </div>
</div>
}

@section Scripts {
<script src="~/js/it-dashboard.js?v=@DateTime.Now.Ticks"></script>
<script src="~/js/it-analytics.js?v=@DateTime.Now.Ticks"></script>
<script>
    async function triggerForceSeed() {
        const result = await Swal.fire({
            title: 'Xác nhận gieo dữ liệu?',
            text: 'Toàn bộ dữ liệu kiểm thử hiện tại sẽ bị xóa sạch hoàn toàn để thiết lập dữ liệu thực tế mới. Hành động này không thể hoàn tác!',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Đồng ý, gieo dữ liệu!',
            cancelButtonText: 'Hủy bỏ',
            customClass: {
                confirmButton: 'btn btn-danger',
                cancelButton: 'btn btn-secondary'
            }
        });

        if (!result.isConfirmed) return;

        Swal.fire({
            title: 'Đang gieo dữ liệu...',
            text: 'Vui lòng chờ trong giây lát.',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });

        try {
            const response = await fetch('/api/it/force-seed', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            });

            const data = await response.json();
            if (response.ok && data.success) {
                await Swal.fire({
                    title: 'Thành công!',
                    text: 'Đã gieo dữ liệu thực tế thành công. Hệ thống sẽ tự động tải lại trang.',
                    icon: 'success'
                });
                location.reload();
            } else {
                Swal.fire({
                    title: 'Thất bại!',
                    text: data.error || 'Đã có lỗi xảy ra khi gieo dữ liệu.',
                    icon: 'error'
                });
            }
        } catch (err) {
            console.error(err);
            Swal.fire({
                title: 'Lỗi kết nối!',
                text: 'Không thể kết nối tới server.',
                icon: 'error'
            });
        }
    }
</script>
}
