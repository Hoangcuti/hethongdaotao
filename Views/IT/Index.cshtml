@{
    ViewData["Title"] = "Dashboard IT Admin";
    Layout = "_Layout";
}
@section Header {
    <meta name="description" content="Dashboard quản trị IT - quản lý tài khoản và hệ thống LMS" />
    <style>
        .builder-item { padding: 10px 14px; background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 8px; margin-bottom: 8px; cursor: grab; display: flex; align-items: center; gap: 10px; }
        .builder-item:hover { border-color: var(--color-primary); background: var(--color-primary-bg-hover); }
        .builder-item.dragging { opacity: 0.5; border: 2px dashed var(--color-primary) !important; }
        .drop-zone-active { background: rgba(59, 130, 246, 0.1) !important; border: 2px dashed var(--color-primary) !important; min-height: 40px; }
        .structure-module { background: var(--card-bg); border-radius: 10px; border: 1px solid var(--card-border); margin-bottom: 15px; overflow: hidden; }
        .structure-module-header { padding: 12px 16px; background: var(--bg-page); border-bottom: 1px solid var(--card-border); display: flex; justify-content: space-between; }
        .structure-module-body { padding: 10px 16px; min-height: 40px; }
        .structure-item { padding: 8px 12px; border: 1px solid #f1f5f9; border-radius: 6px; margin-bottom: 5px; display: flex; justify-content: space-between; font-size: 13px; }
        .role-checkbox-label {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 12px;
            border-radius: 8px;
            background: var(--bg-page);
            border: 1px solid var(--card-border);
            cursor: pointer;
            transition: all 0.2s ease;
        }
        .role-checkbox-label:hover {
            background: var(--color-primary-bg-hover);
            border-color: var(--color-primary);
        }
        .role-checkbox-label input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: var(--color-primary);
            cursor: pointer;
            margin: 0;
        }
        .role-checkbox-label span {
            font-weight: 500;
            color: var(--text-body);
            font-size: 14px;
        }
    </style>
}
<div class="content-area">
    <!-- Nav Pills Removed (now handled by sidebar) -->
    <!-- ====== PAGE: Overview ====== -->
    <div id="overview" class="page-section fade-in" style="background:var(--bg-page); padding:0; display:flex; flex-direction:column; gap:24px;">
        
        <!-- Welcome Card -->
        <div id="admWelcomeCard" class="card welcome-card">
            <div style="display:flex; justify-content:space-between; align-items:center;">
                <div>
                    <h3 style="font-size:18px; font-weight:700; color:var(--text-heading); margin:0 0 4px 0;">Xin chào, @(User.FindFirst("FullName")?.Value ?? Context.Session.GetString("FullName") ?? "Admin") 👋</h3>
                    <p style="font-size:13px; color:var(--text-muted); margin:0;"><span id="admDateWelcome"></span>.</p>
                </div>
                <div style="font-size:13px; color:var(--text-body); display:flex; gap:16px; align-items:center;">
                    <div style="display:flex; align-items:center; gap:6px;"><span style="color:var(--color-warning); font-size:16px;">⏳</span> <span id="admWelcomeTasks">-- công việc cần xử lý</span></div>
                    <div style="display:flex; align-items:center; gap:6px;"><span style="color:var(--color-primary); font-size:16px;">🔔</span> <span id="admWelcomeNotifs">-- thông báo mới</span></div>
                    <div style="display:flex; align-items:center; gap:6px;"><span style="color:var(--color-success); font-size:16px;">🟢</span> <span id="admWelcomeHealth">Hệ thống đang hoạt động bình thường</span></div>
                </div>
            </div>
        </div>

        <!-- Row 1: Core Metrics Grid (7 items) -->
        <div class="adm-metrics-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 16px;">
            <!-- Loading indicator initially -->
            <div id="adm-metrics-loading" style="grid-column: 1 / -1; text-align: center; padding: 40px 0; color: #94a3b8;">
                <div class="spinner" style="margin: 0 auto 12px auto;"></div> Đang tải thông số vận hành...
            </div>
        </div>

        <!-- Row 2: Grid for Operations and Monitoring/Comms (2 Columns layout) -->
        <div style="display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 24px; align-items: start;">
            
            <!-- Left Column: Operations -->
            <div style="display: flex; flex-direction: column; gap: 24px;">
                <!-- Quick Actions Card -->
                <div class="card panel-card">
                    <div class="card-header panel-card-header" style="padding:12px 20px;">
                        <h3 style="font-size:15px; font-weight:700; color:var(--text-heading); margin:0; display:flex; align-items:center; gap:8px;">⚡ Thao tác nhanh</h3>
                    </div>
                    <div class="card-body" style="padding:16px; display:grid; grid-template-columns: repeat(auto-fit, minmax(110px, 1fr)); gap:12px;">
                        <button class="btn btn-primary quick-action-btn" onclick="openCreateUserModal()" style="height:auto; justify-content:center; box-shadow:none;">
                            <span style="font-size:22px;">👤</span>
                            <span style="font-size:12px; font-weight:600;">Thêm người dùng</span>
                        </button>
                        <button class="btn btn-primary quick-action-btn" onclick="openCreateCourseModal()" style="height:auto; justify-content:center; box-shadow:none;">
                            <span style="font-size:22px;">📘</span>
                            <span style="font-size:12px; font-weight:600;">Tạo khóa học</span>
                        </button>
                        <button class="btn btn-primary quick-action-btn" onclick="navigate('exams')" style="height:auto; justify-content:center; box-shadow:none;">
                            <span style="font-size:22px;">📝</span>
                            <span style="font-size:12px; font-weight:600;">Tạo bài thi</span>
                        </button>
                        <button class="btn btn-primary quick-action-btn" onclick="navigate('documents')" style="height:auto; justify-content:center; box-shadow:none;">
                            <span style="font-size:22px;">📤</span>
                            <span style="font-size:12px; font-weight:600;">Upload tài liệu</span>
                        </button>
                        <button class="btn btn-primary quick-action-btn" onclick="triggerQuickBackup()" style="height:auto; justify-content:center; background:linear-gradient(135deg, var(--color-primary-bg-hover), #dbeafe); color:#1e40af; border:1px solid #bfdbfe; box-shadow:none;">
                            <span style="font-size:22px;">💾</span>
                            <span style="font-size:12px; font-weight:700;">Sao lưu Database</span>
                        </button>
                    </div>
                </div>
 
                <!-- Pending Tasks -->
                <div class="card panel-card">
                    <div class="card-header panel-card-header">
                        <h3 style="font-size:16px; font-weight:700; color:var(--text-heading); margin:0; display:flex; align-items:center; gap:8px;">⚖️ Việc cần duyệt gấp</h3>
                    </div>
                    <div class="card-body" id="admPendingGrid" style="padding:20px; display:grid; grid-template-columns:1fr 1fr; gap:16px; min-height:120px; position:relative;">
                        <div class="loading-overlay"><div class="spinner"></div></div>
                    </div>
                </div>
 
                <!-- Recent Activity Timeline -->
                <div class="card panel-card">
                    <div class="card-header panel-card-header">
                        <h3 style="font-size:16px; font-weight:700; color:var(--text-heading); margin:0; display:flex; align-items:center; gap:8px;">🕒 Hoạt động gần đây</h3>
                    </div>
                    <div class="card-body" id="admActivityTimeline" style="padding:20px; min-height:220px; position:relative;">
                        <div class="loading-overlay"><div class="spinner"></div></div>
                    </div>
                </div>
            </div>
            
            <!-- Right Column: Monitoring & Comms -->
            <div style="display: flex; flex-direction: column; gap: 24px;">
                <!-- System Health Card -->
                <div class="card panel-card">
                    <div class="card-header panel-card-header">
                        <h3 style="font-size:16px; font-weight:700; color:var(--text-heading); margin:0; display:flex; align-items:center; gap:8px;">🖥️ Sức khỏe hệ thống</h3>
                    </div>
                    <div class="card-body" id="admSystemHealth" style="padding:20px; min-height:180px; position:relative;">
                        <div class="loading-overlay"><div class="spinner"></div></div>
                    </div>
                </div>

                <!-- Short System Log Card -->
                <div class="card terminal-card">
                    <div class="card-header terminal-header" style="border-bottom:1px solid #334155; display:flex; justify-content:space-between; align-items:center;">
                        <h3 style="font-size:14px; font-weight:700; color:#f8fafc; margin:0; display:flex; align-items:center; gap:8px;">💻 Terminal: Nhật ký hoạt động</h3>
                        <span style="font-size:11px; color:var(--text-faint); font-family:monospace;">live_logs</span>
                    </div>
                    <div class="card-body terminal-body" id="admConsoleLogs" style="padding:16px; max-height:220px; overflow-y:auto; line-height:1.6; min-height:100px;">
                        <div style="color:var(--text-muted);">[system] Đang kết nối tới dòng sự kiện...</div>
                    </div>
                </div>

                <!-- Notification Center Card -->
                <div class="card panel-card">
                    <div class="card-header panel-card-header" style="display:flex; justify-content:space-between; align-items:center;">
                        <h3 style="font-size:16px; font-weight:700; color:var(--text-heading); margin:0; display:flex; align-items:center; gap:8px;">🔔 Trung tâm thông báo <span id="adm-notif-unread-count" class="badge badge-danger" style="display:none; font-size:11px;">0</span></h3>
                        <button class="btn btn-sm btn-outline" onclick="markAllNotificationsRead()" style="font-size:12px; padding:4px 8px; border-color:var(--card-border); color:var(--text-body);">Đọc tất cả</button>
                    </div>
                    <div class="card-body" id="admNotificationsList" style="padding:10px 20px; max-height:280px; overflow-y:auto; min-height:120px; position:relative;">
                        <div class="loading-overlay"><div class="spinner"></div></div>
                    </div>
                </div>
            </div>
            
        </div>
    </div>


    <!-- ====== PAGE: Users ====== -->
    <div id="users" class="page-section" style="display:none">
        <div class="card" style="margin-bottom:16px">
            <div class="card-body" style="padding:14px 20px">
                <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center">
                    <div class="input-wrap" style="flex:1;min-width:200px">
                        <span class="input-icon">🔍</span>
                        <input id="userSearch" type="text" class="form-input with-icon" placeholder="Tìm tên, email, mã NV..." oninput="debouncedLoadUsers()">
                    </div>
                    <button class="btn btn-secondary" data-permission="users.manage" onclick="openBulkDeptModal()">
                        🚀 Đẩy NV vào phòng ban
                    </button>
                    <button class="btn btn-primary" data-permission="users.manage" onclick="openCreateUserModal();">
                        👤 Tạo tài khoản
                    </button>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="table-wrapper">
                <table class="lms-table">
                    <thead>
                        <tr>
                            <th style="width:40px"><input type="checkbox" id="selectAllUsers" onclick="toggleSelectAll(this)"></th>
                            <th>Nhân viên</th>
                            <th>Mã NV</th>
                            <th>Phòng ban</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="usersTable">
                        <tr><td colspan="7"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                    </tbody>
                </table>
            </div>
            <div id="usersPagination" class="pagination"></div>
        </div>
    </div>

    <!-- ====== PAGE: Courses ====== -->
    <div id="courses" class="page-section" style="display:none">
        <div class="card" style="margin-bottom:16px">
            <div class="card-body" style="padding:14px 20px; display:flex; justify-content:space-between; align-items:center">
                <div class="input-wrap" style="flex:1; max-width:400px">
                    <span class="input-icon">🔍</span>
                    <input id="courseSearch" type="text" class="form-input with-icon" placeholder="Tìm tên khóa học..." oninput="debouncedLoadItCourses()">
                </div>
                <button class="btn btn-primary" onclick="openCreateCourseModal()">➕ Thêm Khóa Học</button>
            </div>
        </div>
        <div class="card">
            <div class="table-wrapper">
                <table class="lms-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Mã KH</th>
                            <th>Tên khóa học</th>
                            <th>Level</th>
                            <th>Danh mục</th>
                            <th>Bắt buộc</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="itCoursesTable">
                        <tr><td colspan="8"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ====== PAGE: Departments ====== -->
    <div id="departments" class="page-section" style="display:none">
        <div class="card" style="margin-bottom:16px">
            <div class="card-body" style="padding:14px 20px; display:flex; justify-content:flex-end">
                <button class="btn btn-primary" onclick="openCreateDeptModal()">➕ Thêm Phòng Ban</button>
            </div>
        </div>
        <div class="card">
            <div class="table-wrapper">
                <table class="lms-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Tên phòng ban</th>
                            <th>Trưởng phòng</th>
                            <th>Số lượng NV</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="itDepartmentsTable">
                        <tr><td colspan="5"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ====== PAGE: Audit Logs ====== -->
    <div id="auditlogs" class="page-section" style="display:none">
        <div class="card">
            <div class="table-wrapper">
                <table class="lms-table">
                    <thead>
                        <tr>
                            <th>Thời gian</th>
                            <th>Người thực hiện</th>
                            <th>Hành động</th>
                            <th>Chi tiết</th>
                        </tr>
                    </thead>
                    <tbody id="fullAuditLogsTable">
                        <tr><td colspan="4"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                    </tbody>
                </table>
            </div>
            <div id="auditPagination" class="pagination"></div>
        </div>
    </div>

    <!-- ====== PAGE: Categories ====== -->
    <div id="categories" class="page-section" style="display:none">
        <div class="card" style="margin-bottom:16px">
            <div class="card-body" style="padding:14px 20px; display:flex; justify-content:flex-end">
                <button class="btn btn-primary" onclick="openCreateCategoryModal()">➕ Thêm Danh Mục</button>
            </div>
        </div>
        <div class="card">
            <div class="table-wrapper">
                <table class="lms-table">
                    <thead>
                        <tr>
                            <th>ID</th><th>Tên danh mục</th><th>Khóa học</th><th>FAQ</th><th>Ngân hàng câu hỏi</th><th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="categoriesTable">
                        <tr><td colspan="6"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ====== PAGE: FAQ ====== -->
    <div id="faqs" class="page-section" style="display:none">
        <div class="card" style="margin-bottom:16px">
            <div class="card-body" style="padding:14px 20px; display:flex; gap:12px; justify-content:space-between; align-items:center">
                <div class="input-wrap" style="flex:1; max-width:400px">
                    <span class="input-icon">🔍</span>
                    <input id="faqSearch" type="text" class="form-input with-icon" placeholder="Tìm câu hỏi..." oninput="debouncedLoadFaqs()">
                </div>
                <button class="btn btn-primary" onclick="openCreateFaqModal()">➕ Thêm FAQ</button>
            </div>
        </div>
        <div class="card">
            <div class="table-wrapper">
                <table class="lms-table">
                    <thead>
                        <tr>
                            <th style="width:40%">Câu hỏi</th><th>Câu trả lời</th><th>Danh mục</th><th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="faqsTable">
                        <tr><td colspan="4"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ======= PAGE: EXAMS ======= -->
    <div id="exams" class="page-section" style="display:none">
        <div class="card" style="margin-bottom:16px">
            <div class="card-header" style="border-bottom:none; padding-bottom:6px; display:flex; justify-content:space-between; align-items:center;">
                <div>
                    <div class="card-title">📝 Quản lý bài kiểm tra & Đánh giá</div>
                    <div class="card-subtitle">Theo dõi thống kê Đạt / Không đạt và thiết lập cấu trúc đề thi kéo thả.</div>
                </div>
                <button class="btn btn-primary" onclick="openCreateExamModal()">➕ Tạo bài thi mới</button>
            </div>
        </div>

        <div class="card" style="margin-bottom:16px">
            <div class="card-body" style="padding:14px 20px">
                <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center">
                    <div class="input-wrap" style="flex:1;min-width:240px">
                        <span class="input-icon">🔍</span>
                        <input id="examsSearch" type="text" class="form-input with-icon" placeholder="Tìm theo tên bài thi hoặc khóa học..." oninput="renderExamsPageList()">
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="table-wrapper">
                <table class="lms-table">
                    <thead>
                        <tr>
                            <th style="width:50px">ID</th>
                            <th>Tên bài thi</th>
                            <th>Khóa học</th>
                            <th>Số câu hỏi</th>
                            <th>Thời gian</th>
                            <th>Điểm qua</th>
                            <th>Đạt</th>
                            <th>Không đạt</th>
                            <th style="text-align:right">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="examsTableBody">
                        <tr><td colspan="9"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ====== PAGE: Document Library ====== -->
    <div id="documents" class="page-section" style="display:none">
        <div class="card" style="margin-bottom:16px">
            <div class="card-header" style="border-bottom:none; padding-bottom:6px">
                <div>
                    <div class="card-title">📚 Kho tài liệu hệ thống</div>
                    <div class="card-subtitle">Quản lý kho chương, bài giảng và quiz trong toàn hệ thống.</div>
                </div>
            </div>
            <div class="card-body" style="padding-top:0">
                <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center;justify-content:space-between">
                    <div style="display:flex;gap:10px;flex-wrap:wrap">
                        <button id="libraryTabModules" class="btn btn-primary" onclick="switchLibraryTab('modules')">🧩 Kho Chương</button>
                        <button id="libraryTabLessons" class="btn btn-secondary" onclick="switchLibraryTab('lessons')">📝 Kho Bài Giảng</button>
                        <button id="libraryTabExams" class="btn btn-secondary" onclick="switchLibraryTab('exams')">❓ Kho Quiz</button>
                        <button id="libraryTabQuestions" class="btn btn-secondary" onclick="switchLibraryTab('questions')">❓ Kho Câu Hỏi</button>
                    </div>
                    <button id="libraryCreateBtn" class="btn btn-primary" onclick="openLibraryCreateModal()">➕ Tạo mới</button>
                </div>
                <div id="questionsSubTabs" style="display:none; gap:10px; margin-top:10px; padding-top:10px; border-top:1px solid #e2e8f0; flex-wrap:wrap; align-items:center">
                    <span style="font-weight:600; color:#4a5568; margin-right:8px; display:inline-flex; align-items:center">Phân loại:</span>
                    <button id="qSubTabAll" class="btn btn-primary btn-sm question-sub-tab" onclick="switchQuestionSubTab('all')">Tất cả</button>
                    <button id="qSubTabMC" class="btn btn-secondary btn-sm question-sub-tab" onclick="switchQuestionSubTab('MultipleChoice')">☑️ Trắc nghiệm</button>
                    <button id="qSubTabEssay" class="btn btn-secondary btn-sm question-sub-tab" onclick="switchQuestionSubTab('Essay')">✍️ Tự luận</button>
                    <button id="qSubTabFITB" class="btn btn-secondary btn-sm question-sub-tab" onclick="switchQuestionSubTab('FillInTheBlank')">✏️ Điền từ</button>
                </div>
            </div>
        </div>

        <div class="card" style="margin-bottom:16px">
            <div class="card-body" style="padding:14px 20px">
                <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:center">
                    <div class="input-wrap" style="flex:1;min-width:240px">
                        <span class="input-icon">🔍</span>
                        <input id="librarySearch" type="text" class="form-input with-icon" placeholder="Tìm theo tên chương, bài giảng, quiz hoặc khóa học..." oninput="renderDocumentLibrary()">
                    </div>
                    <select id="libraryDeptFilter" class="form-input" style="width:220px" onchange="renderDocumentLibrary()">
                        <option value="">Tất cả phòng ban</option>
                    </select>
                    <select id="libraryCourseFilter" class="form-input" style="width:260px" onchange="renderDocumentLibrary()">
                        <option value="">Tất cả khóa học</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="stats-grid" style="margin-bottom:16px">
            <div class="stat-card blue">
                <div class="stat-icon blue">🧩</div>
                <div class="stat-value" id="libraryModulesCount">0</div>
                <div class="stat-label">Tổng số chương</div>
            </div>
            <div class="stat-card green">
                <div class="stat-icon green">📝</div>
                <div class="stat-value" id="libraryLessonsCount">0</div>
                <div class="stat-label">Tổng số bài giảng</div>
            </div>
            <div class="stat-card cyan">
                <div class="stat-icon cyan">📎</div>
                <div class="stat-value" id="libraryAttachmentsCount">0</div>
                <div class="stat-label">Tổng số tài liệu</div>
            </div>
            <div class="stat-card orange">
                <div class="stat-icon orange">❓</div>
                <div class="stat-value" id="libraryExamsCount">0</div>
                <div class="stat-label">Tổng số Quiz</div>
            </div>
        </div>
        <div class="card">
            <div class="table-wrapper">
                <table class="lms-table">
                    <thead id="documentLibraryHead"></thead>
                    <tbody id="documentLibraryTable">
                        <tr><td colspan="6"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                    </tbody>
