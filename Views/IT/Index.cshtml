        </div>
        <div class="modal-footer">
            <button class="btn btn-secondary" onclick="closeModal('questionPoolEditModal')">Hủy</button>
            <button class="btn btn-primary" onclick="submitQuestionPoolSave()">💾 Lưu câu hỏi</button>
